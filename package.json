{
  "name": "cyclone-frontend",
  "version": "1.0.0",
  "private": true,
  "proxy": "http://localhost:5010",
  "scripts": {
    "start": "BROWSER=none DANGEROUSLY_DISABLE_HOST_CHECK=true PORT=5006 REACT_APP_API_PORT=5010 react-scripts start",
    "server": "node server.js",
    "dev": "concurrently \"PORT=5010 npm run server\" \"npm start\"",
    "ngrok": "ngrok http 5006 --host-header=localhost:5006",
    "build": "react-scripts build"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.2",
    "mysql2": "^3.22.5",
    "pg": "^8.21.0",
    "pg-hstore": "^2.3.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "nodemon": "^3.1.14"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}